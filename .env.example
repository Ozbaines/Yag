# ===== LLM Backend =====
# "openai_compat" — Groq (бесплатно), Ollama, OpenRouter и т.д.
# "claude"        — Anthropic Claude (платно)
LLM_BACKEND=openai_compat

# Groq (бесплатно) — https://console.groq.com
OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=llama-3.3-70b-versatile

# Anthropic Claude (нужен только если LLM_BACKEND=claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL_FAST=claude-sonnet-4-6
CLAUDE_MODEL_SMART=claude-opus-4-7

# ===== Database =====
POSTGRES_USER=yag
POSTGRES_PASSWORD=yag_dev_password
POSTGRES_DB=yag
DATABASE_URL=postgresql+asyncpg://yag:yag_dev_password@postgres:5432/yag
REDIS_URL=redis://redis:6379/0

# ===== Telegram =====
# Bot owner (admin) — accepts/rejects drafts
TG_ADMIN_BOT_TOKEN=
TG_ADMIN_USER_ID=

# Public channel where approved content goes
TG_CHANNEL_ID=@your_channel
TG_CHANNEL_URL=https://t.me/your_channel

# Subscriber bot — warms up audience
TG_SUBSCRIBER_BOT_TOKEN=
TG_SUBSCRIBER_BOT_USERNAME=your_subscriber_bot

# ===== Sources =====
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=YAg/1.0
X_BEARER_TOKEN=

# ===== Publishing =====
# Instagram Graph API (Reels)
IG_USER_ID=
IG_ACCESS_TOKEN=

# YouTube Data API v3 (Shorts upload via OAuth)
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=

# ===== Payments =====
# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Prodamus
PRODAMUS_SHOP=
PRODAMUS_SECRET=

# ===== Landing =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_TG_BOT_URL=https://t.me/your_subscriber_bot
PAYMENTS_API_URL=http://payments:8000

# ===== Misc =====
TZ=Europe/Moscow
LOG_LEVEL=INFO
STORAGE_DIR=/app/storage
